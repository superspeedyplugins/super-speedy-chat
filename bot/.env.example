# Discord Bot Token (from Discord Developer Portal > Bot > Token)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord Channel ID (right-click channel > Copy Channel ID)
DISCORD_CHANNEL_ID=your_channel_id_here

# WordPress REST endpoint URL (from Super Speedy Chat > Discord > Bot Connection Info)
WP_ENDPOINT_URL=https://yoursite.com/wp-json/ssc/v1/discord/incoming

# Webhook Secret (from Super Speedy Chat > Discord > Bot Connection Info)
WP_WEBHOOK_SECRET=your_webhook_secret_here
